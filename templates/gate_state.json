      "strategy_name": "ULTRA-NARROW",
      "max_hops": 1,
      "tools_permitted": ["get_impact_radius_tool"],
      "architecture_overview_required": false
    },
    "release": {
      "strategy_name": "DIFF-ONLY",
      "max_hops": null,
      "tools_permitted": ["get_review_context_tool"],
      "architecture_overview_required": false,
      "code_writes_permitted": false
    }
  },

