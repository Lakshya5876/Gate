  },

  "branch_strategy": {
    "feature": {
      "strategy_name": "BROAD",
      "max_hops": null,
      "tools_permitted": ["get_architecture_overview_tool", "semantic_search_nodes_tool", "get_impact_radius_tool", "query_graph_tool", "get_review_context_tool"],
      "architecture_overview_required": true
